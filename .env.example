# ------------------------------------------------------------------------
# Environment Setup Example
# ------------------------------------------------------------------------
# 1. Copy this file to '.env'
# 2. Add your actual API keys and secrets below
# 
# DO NOT COMMIT your actual '.env' file to version control.
# ------------------------------------------------------------------------

# Your Groq API key (if using Groq LLM)
GROQ_API_KEY="gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Your Google AI Studio API key (if using Gemini LLM - Recommended if Groq is restricted)
# Get one for free at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Path to Verilator binary (e.g., C:\verilator-v5.006\bin\verilator_bin.exe or just 'verilator')
VERILATOR_BIN="verilator"

# Number of times the engine will try to fix the Verilog code if linting fails
MAX_AUTO_FIX_ATTEMPTS=3
